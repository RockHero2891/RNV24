# =============================================================================
# RNV24 — Environment variables
# Copy to .env and fill in values. NEVER commit real secrets.
# =============================================================================

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Auth (required in production) ---
# Generate: [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# --- Database (pick ONE mode) ---
# Local dev: SQLite (default when DATABASE_URL is unset)
DATABASE_PATH=./data/rnv24.db

# Production: Neon PostgreSQL (uncomment and paste from Neon dashboard)
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- OpenAI (optional — enables AI code validation) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Frontend ---
# Local dev with Vite proxy: leave empty or use http://localhost:3001
# Production single-service (Docker/Render): leave empty (same origin)
VITE_API_URL=
